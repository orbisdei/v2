{
  "expo": {
    "name": "Orbis Dei",
    "slug": "orbis-dei",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "orbisdei",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "org.orbisdei.app",
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "org.orbisdei.app",
      "adaptiveIcon": {
        "backgroundColor": "#1e1e5f",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Orbis Dei uses your location to show holy sites near you."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1e1e5f",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bcaab62c-84c0-4c8c-a3bf-85558e9818f6"
      }
    },
    "owner": "orbis-dei"
  }
}
